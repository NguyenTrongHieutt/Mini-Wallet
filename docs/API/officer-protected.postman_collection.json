        },
        "url": "{{baseUrl}}/api/v1/officer/pockets/lock"
      }
    },
    {
      "name": "Unlock pocket",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.test('Pocket unlock succeeds', function () { pm.expect(json.err).to.eql(200); });",
              "pm.test('Pocket is active', function () { pm.expect(json.data.pocket.status).to.eql('active'); });"
