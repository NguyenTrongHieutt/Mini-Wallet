    {
      "name": "Lock pocket",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.test('Pocket lock succeeds', function () { pm.expect(json.err).to.eql(200); });",
              "pm.test('Pocket is locked', function () { pm.expect(json.data.pocket.status).to.eql('locked'); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
